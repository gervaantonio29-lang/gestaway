# ============================================================
# GESTAWAY — .env
# Copia questo file in .env e compila i valori
# NON committare mai il .env nel repository
# ============================================================

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # oppure: production

# URL pubblico del server (usato per registrare il webhook su Channex)
# Es: https://gestaway.tuodominio.com
BASE_URL=https://tuo-dominio.com

# ── Auth ──────────────────────────────────────────────────────
ADMIN_PASSWORD=cambia-questa-password-sicura

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # service_role key (NON anon key)

# ── Channex ───────────────────────────────────────────────────
# Genera la API key in: Channex Dashboard → Properties → API Keys
CHANNEX_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 'staging' per i test di certificazione, 'production' per il live
# (default: staging se non specificato)
CHANNEX_ENV=staging
